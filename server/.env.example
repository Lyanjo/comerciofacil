# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3333
NODE_ENV=production

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Gere um segredo forte: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque-por-um-segredo-forte
JWT_EXPIRES_IN=7d

# ─── Banco de dados (Railway PostgreSQL) ─────────────────────────────────────
# O Railway preenche automaticamente quando você adiciona o plugin PostgreSQL
DATABASE_URL=postgresql://user:password@host:port/dbname

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL do seu frontend no GitHub Pages
FRONTEND_URL=https://lyanjo.github.io
